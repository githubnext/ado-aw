---
// Custom head component for ado-aw docs
// Adds Mona Sans preload and Schema.org structured data
---

<link
  rel="preload"
  href="/ado-aw/fonts/Mona-Sans.woff2"
  as="font"
  type="font/woff2"
  crossorigin
/>

{Astro.url.pathname === '/ado-aw/' && (
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "SoftwareApplication",
        "name": "ado-aw",
        "description": "Compiler for Azure DevOps agentic pipelines from natural-language markdown",
        "applicationCategory": "DeveloperApplication",
        "operatingSystem": "Cross-platform",
        "url": "https://githubnext.github.io/ado-aw/",
        "codeRepository": "https://github.com/githubnext/ado-aw"
      },
      {
        "@type": "WebSite",
        "name": "ado-aw Documentation",
        "url": "https://githubnext.github.io/ado-aw/"
      }
    ]
  })} />
)}

          "jsonpath": "$.plugins[0].version"
        },
        "agency/plugins/ado-aw/agents/ado-aw.md",
        "agency/plugins/ado-aw/skills/create-workflow/SKILL.md",
        "agency/plugins/ado-aw/skills/update-workflow/SKILL.md",
